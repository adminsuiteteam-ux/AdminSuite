# ==============================================================================
# Admin Suite Backend — Environment Variables Configuration Template
# ==============================================================================
# Copy this file to a file named `.env` in the same directory and fill in
# your production values. DO NOT commit `.env` files with real keys to Git.
# ==============================================================================

# ── Django Security Configuration ─────────────────────────────────────────────
# In production, set this to a random 50-character string. Keep it secret!
DJANGO_SECRET_KEY=django-insecure-prod-key-please-replace-with-something-highly-random-and-secure

# Set to "False" in production to prevent displaying debug pages/queries/traces.
DJANGO_DEBUG=False

# Comma-separated list of hosts/domains that this Django site is allowed to serve.
# Must include your backend API host domain.
DJANGO_ALLOWED_HOSTS=api.adminsuite.app,localhost,127.0.0.1

# ── Cross-Origin Resource Sharing (CORS) ──────────────────────────────────────
# Comma-separated list of origins allowed to make HTTP/HTTPS API requests.
# Must include your mobile app hosting/web origin if applicable, or custom domains.
CORS_ALLOWED_ORIGINS=https://adminsuite.app,https://admin.adminsuite.app

# ── Database Configuration (Primary: Supabase Postgres) ────────────────────────
# Your Supabase connection string. DRF parses this automatically in production.
# Example: postgresql://postgres.xxxx:yourpassword@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<dbname>?sslmode=require

# ── Sentry Error Monitoring ───────────────────────────────────────────────────
# Paste your Sentry DSN from https://sentry.io -> Project -> Client Keys
SENTRY_DSN=YOUR_SENTRY_DSN_HERE

# ── AI / Gemini Configuration ──────────────────────────────────────────────
# Get your free API key from https://aistudio.google.com/app/apikey
# The key is free for development; production usage costs ~$8/month per 100 users
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Master switch — set to False to disable all AI features
AI_ENABLED=True


